    "faq_ip4tCb": {
      "type": "faq",
      "blocks": {
        "item_HVPTqw": {
          "type": "item",
          "settings": {
            "title": "Vos produits sont-ils authentiques ?",
            "content": "<p>Oui, <strong>100%</strong>. Tous nos soins sont importés directement depuis la Corée du Sud auprès des marques officielles, et stockés en France. Nous garantissons <strong>la traçabilité et l’authenticité</strong> de chaque produit. </p>"
          }
        },
        "item_DwLfqa": {
          "type": "item",
          "settings": {
            "title": "En combien de temps vais-je recevoir ma commande ?",
            "content": "<p>Les commandes sont expédiées <strong>sous 24h</strong> (hors week-end et jours fériés) depuis notre entrepôt.</p><p><strong>La livraison offerte</strong> à domicile dès 50€, prennent <strong>2 à 5 jours ouvrés en France.</strong></p>"
          }
        },
        "item_eDMwfq": {
          "type": "item",
          "settings": {
            "title": "Puis-je retourner un produit s’il ne me convient pas ?",
            "content": "<p>Oui, vous avez <strong>14 jours</strong> pour nous le renvoyer si le produit n’a pas été ouvert.</p><p>Il suffit de nous contacter via <strong>la page contact </strong>ou directement par mail : <strong>zelyasupport@gmail.com </strong>et on s’occupera du reste !</p>"
          }
        }
      },
      "block_order": [
        "item_HVPTqw",
